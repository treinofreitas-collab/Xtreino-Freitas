rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Fotos de perfil: usuários podem ler/escrever apenas suas próprias fotos
    match /profile-photos/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // Outros arquivos: apenas leitura pública (se necessário)
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false; // Desabilitar uploads não autorizados por padrão
    }
  }
}

